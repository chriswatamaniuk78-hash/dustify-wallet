# Dustify Wallet
NEXT_PUBLIC_APP_URL=https://wallet.dustifytechnologiescorp.com
ALLOWED_ORIGINS=https://wallet.dustifytechnologiescorp.com,http://localhost:3001

NEXT_PUBLIC_CHAIN_ID=137
POLYGON_RPC_URL=
NEXT_PUBLIC_POLYGON_RPC=
NEXT_PUBLIC_DUSTID_CONTRACT=
NEXT_PUBLIC_DUST_PHOENIX_V2=
NEXT_PUBLIC_HONEYPOT_VAULT=

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

NEXT_PUBLIC_REWARDS_RATE=100

ALPACA_API_KEY=
ALPACA_SECRET_KEY=
COINBASE_API_KEY=
COINBASE_API_SECRET=
OANDA_API_KEY=
OANDA_ACCOUNT_ID=

PHOENIX_RESURRECTION_COMMITMENT=

# ── Security Hardening (April 2026 Audit) ─────────────────
# Generate each with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Inter-app authentication
DUSTIFY_INTER_APP_SECRET=dst_iap_[generate_64_random_hex_chars]

# Webhook HMAC signing
DUSTIFY_WEBHOOK_SECRET=dst_wh_[generate_64_random_hex_chars]

# AES-256 encryption key (exactly 64 hex chars = 32 bytes)
DUSTIFY_VAULT_KEY=[generate_64_hex_chars_for_aes_256]

# Vercel Cron job secret
CRON_SECRET=[generate_32_random_hex_chars]

# Redis rate limiter (Upstash recommended)
REDIS_URL=rediss://default:[password]@[endpoint].upstash.io:6379

# Security alert email
SECURITY_ALERT_EMAIL=chris@dustifytechnologiescorp.com

