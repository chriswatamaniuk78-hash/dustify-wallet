# ============================================================
# SOUL WALLET PWA — Environment Variables
# Copy to .env.local — NEVER commit actual values
# Dustify Technologies Corp · Edmonton, Alberta, Canada 🍁
# ============================================================

# ── CORE PLATFORM ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://wallet.dustifytechnologiescorp.com
NEXT_PUBLIC_API_URL=https://api.dustifytechnologiescorp.com
# During local dev:
# NEXT_PUBLIC_API_URL=http://localhost:3001

# ── SUPABASE ──────────────────────────────────────────────────
# Get from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── POLYGON / BLOCKCHAIN ──────────────────────────────────────
# Get from: https://alchemy.com
NEXT_PUBLIC_POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
# Deployed contract addresses (after running deploy script)
NEXT_PUBLIC_DUST_ID_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_DUST_MILES_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_DUST_PAYMASTER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_DUST_REDEEMER_ADDRESS=0x0000000000000000000000000000000000000000
# ERC-4337 Bundler
NEXT_PUBLIC_BUNDLER_URL=https://api.pimlico.io/v2/137/rpc?apikey=YOUR_KEY

# ── PUSH NOTIFICATIONS ────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BNxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── ANALYTICS (optional) ──────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── SENTRY (optional) ─────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# ── BUILD INFO (auto-set by next.config.ts) ───────────────────
# NEXT_PUBLIC_BUILD_TIME=<auto>
# NEXT_PUBLIC_APP_VERSION=2.0.0
